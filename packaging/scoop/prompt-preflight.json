{
  "version": "0.2.0",
  "description": "Rewrite rough prompts into clearer ones with Claude Haiku before a stronger model",
  "homepage": "https://github.com/AnotherSamWithADream/prompt-preflight",
  "license": "MIT",
  "depends": "python",
  "installer": {
    "script": [
